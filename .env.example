OPENAI_API_KEY=
NEXT_PUBLIC_APP_NAME=전시 챗봇

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 임베딩/챗 모델 (프로젝트 기간 동안 고정 권장)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
# 답변 최대 토큰(낮을수록 생성·비용 짧음, 기본 680)
# OPENAI_CHAT_MAX_TOKENS=680
# 오프토픽 분류 전용 모델(비우면 CHAT 모델과 동일)
# OPENAI_TOPIC_MODEL=gpt-4o-mini
# 파일에서 읽는 범위 설명 최대 글자(기본 3800, 짧을수록 분류 호출 약간 빨라짐)
# PROJECT_SCOPE_SNIPPET_MAX_CHARS=3800
# 미디어 추출(npm run extract:media): 이미지 Vision / PDF 텍스트 부족 시 파일 비전
# OPENAI_VISION_MODEL=gpt-4o-mini
# OPENAI_PDF_VISION_MODEL=gpt-4o
# PDF 텍스트만으로 충분하다고 볼 최소 글자수 (기본 200)
# PDF_TEXT_MIN_CHARS=200

# 오프토픽 가드(비우면 wiki/canonical/00_project_overview.md 앞 6000자 사용)
# PROJECT_SCOPE_SNIPPET=

# 주제 분류 스킵(로컬 테스트용): 1
# DISABLE_TOPIC_GUARD=

# digest 스크립트: 소스에서 최대 맵 청크 수
# DIGEST_MAX_CHUNKS=36

# RAG 게이트 (코사인 유사도에 가까운 스코어: 0~1, 코드 기본값은 더 완화됨)
WIKI_MATCH_THRESHOLD=0.21
RAW_MATCH_THRESHOLD=0.2
WIKI_MARGIN_MIN=0.018
# 벡터 RPC 후보(낮을수록 많이 가져옴, 기본 0.05)
# WIKI_RECALL_FLOOR=0.05
# RAW_RECALL_FLOOR=0.05
# 위키 RPC limit (기본 12)
# WIKI_MATCH_COUNT=12
# 「한 줄 소개」류 질문 시 개요 청크 유사도 가산 (기본 0.12)
# WIKI_INTRO_SECTION_BOOST=0.12

# 전시 운영
ADMIN_SECRET=change-me-long-random
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# 선택: 정적 폴백 FAQ (JSON 문자열)
# NEXT_PUBLIC_STATIC_FAQ_JSON=[{"q":"프로젝트 주제는?","a":"..."}]
