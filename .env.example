OPENAI_API_KEY=
NEXT_PUBLIC_APP_NAME=전시 챗봇

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 임베딩/챗 모델 (프로젝트 기간 동안 고정 권장)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# 오프토픽 가드(비우면 wiki/canonical/00_project_overview.md 앞 6000자 사용)
# PROJECT_SCOPE_SNIPPET=

# 주제 분류 스킵(로컬 테스트용): 1
# DISABLE_TOPIC_GUARD=

# digest 스크립트: 소스에서 최대 맵 청크 수
# DIGEST_MAX_CHUNKS=36

# RAG 게이트 (코사인 유사도에 가까운 스코어: 0~1)
WIKI_MATCH_THRESHOLD=0.28
RAW_MATCH_THRESHOLD=0.25
WIKI_MARGIN_MIN=0.02

# 전시 운영
ADMIN_SECRET=change-me-long-random
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20

# 선택: 정적 폴백 FAQ (JSON 문자열)
# NEXT_PUBLIC_STATIC_FAQ_JSON=[{"q":"프로젝트 주제는?","a":"..."}]
