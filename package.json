{
  "name": "exhibition-chatbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "ingest:wiki": "tsx scripts/ingest-wiki.ts",
    "ingest:raw": "tsx scripts/ingest-raw.ts",
    "digest:canonical": "tsx scripts/digest-sources-to-canonical.ts",
    "digest:all-canonical": "tsx scripts/digest-all-canonical.ts",
    "sync:knowledge": "npm run ingest:raw && npm run ingest:wiki",
    "sync:knowledge:with-digest": "npm run digest:all-canonical && npm run sync:knowledge"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.3.24",
    "@ai-sdk/react": "^1.2.12",
    "@supabase/supabase-js": "^2.49.1",
    "ai": "^4.3.19",
    "next": "^15.2.4",
    "openai": "^4.96.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "dotenv": "^16.6.1",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.2.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
